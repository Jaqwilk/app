{
  "expo": {
    "name": "FridgeAI",
    "slug": "fridgeai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fridgeai",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fridgeai.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Scan your fridge to detect ingredients",
        "NSPhotoLibraryUsageDescription": "Select fridge photos to analyze"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.fridgeai.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow FridgeAI to access your camera to scan your fridge"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow FridgeAI to access your photos to select fridge images"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
